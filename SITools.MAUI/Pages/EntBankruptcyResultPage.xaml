<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SITools.MAUI.Pages.EntBankruptcyResultPage"
             Title="清算计算结果">

    <VerticalStackLayout>
        <!-- Tab Buttons -->
        <Grid ColumnDefinitions="*,*" HeightRequest="44" BackgroundColor="#1565C0">
            <Button Grid.Column="0" x:Name="btnTabDetail" Text="逐条明细"
                    BackgroundColor="#1565C0" TextColor="White" FontSize="15"
                    Clicked="OnShowDetail" />
            <Button Grid.Column="1" x:Name="btnTabSummary" Text="险种汇总"
                    BackgroundColor="#0D47A1" TextColor="White" FontSize="15"
                    Clicked="OnShowSummary" />
        </Grid>

        <!-- Detail List -->
        <CollectionView x:Name="cvDetail" IsVisible="True">
            <CollectionView.Header>
                <Label Text="逐条明细" FontSize="14" FontAttributes="Bold"
                       Margin="12,8,12,4" TextColor="#1565C0" />
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="8,4" Padding="10" BackgroundColor="#FAFAFA"
                            StrokeShape="RoundRectangle 6" StrokeThickness="1" Stroke="#E0E0E0">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding HeaderText}" FontSize="13" FontAttributes="Bold" />
                            <Label Text="{Binding DetailText}" FontSize="12" TextColor="#555" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Summary List -->
        <CollectionView x:Name="cvSummary" IsVisible="False">
            <CollectionView.Header>
                <Label Text="险种汇总" FontSize="14" FontAttributes="Bold"
                       Margin="12,8,12,4" TextColor="#1565C0" />
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="8,4" Padding="10" BackgroundColor="#FAFAFA"
                            StrokeShape="RoundRectangle 6" StrokeThickness="1" Stroke="#E0E0E0">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding HeaderText}" FontSize="13" FontAttributes="Bold" />
                            <Label Text="{Binding DetailText}" FontSize="12" TextColor="#555" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>
