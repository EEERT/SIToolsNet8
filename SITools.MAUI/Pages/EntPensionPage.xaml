<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SITools.MAUI.Pages.EntPensionPage"
             Title="企业养老补缴计算">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="8">

            <!-- ===== 补缴记录录入 ===== -->
            <Label Text="补缴记录录入" FontSize="18" FontAttributes="Bold" Margin="0,8,0,4" />

            <Label Text="姓名" />
            <Entry x:Name="entryName" Placeholder="请输入姓名" />

            <Label Text="身份证号码" />
            <Entry x:Name="entryIdCard" Placeholder="请输入18位身份证号" Keyboard="Default" />

            <Label Text="补缴类型" />
            <Picker x:Name="pickerType" Title="请选择补缴类型" />

            <Label Text="补缴起始期（yyyyMM，如198601）" />
            <Entry x:Name="entryBegin" Placeholder="如：198601" Keyboard="Numeric" MaxLength="6" />

            <Label Text="补缴截止期（yyyyMM，如202412）" />
            <Entry x:Name="entryEnd" Placeholder="如：202412" Keyboard="Numeric" MaxLength="6" />

            <Label Text="月缴费基数（元）" />
            <Entry x:Name="entryBase" Placeholder="请输入月缴费基数" Keyboard="Numeric" />

            <Label Text="是否按基数上下限保底" />
            <Picker x:Name="pickerApplyLimit" Title="请选择">
                <Picker.Items>
                    <x:String>是</x:String>
                    <x:String>否</x:String>
                </Picker.Items>
            </Picker>

            <Button Text="添加记录" Clicked="OnAddRecord"
                    BackgroundColor="#1565C0" TextColor="White" CornerRadius="6" />

            <!-- ===== 已添加记录列表 ===== -->
            <Label x:Name="labelRecordCount" Text="已添加记录：0条"
                   FontSize="14" FontAttributes="Bold" Margin="0,8,0,2" />

            <CollectionView x:Name="cvRecords">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,2" Padding="10" BackgroundColor="#E3F2FD"
                                StrokeShape="RoundRectangle 6" StrokeThickness="0">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
                                <Label Grid.Column="0" Text="{Binding DisplayText}"
                                       FontSize="13" LineBreakMode="WordWrap" />
                                <Button Grid.Column="1" Text="删除"
                                        BackgroundColor="#EF5350" TextColor="White"
                                        FontSize="12" HeightRequest="36" WidthRequest="52"
                                        CornerRadius="4" VerticalOptions="Center"
                                        CommandParameter="{Binding .}"
                                        Clicked="OnDeleteRecord" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <BoxView HeightRequest="1" BackgroundColor="LightGray" Margin="0,12" />

            <!-- ===== 计算选项 ===== -->
            <Label Text="计算选项" FontSize="18" FontAttributes="Bold" Margin="0,0,0,4" />

            <Label Text="是否计算利息" />
            <Picker x:Name="pickerCalcInterest" Title="请选择">
                <Picker.Items>
                    <x:String>是</x:String>
                    <x:String>否</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="利息截止日期" />
            <DatePicker x:Name="dpInterestEnd" Format="yyyy-MM-dd" />

            <Label Text="是否计算滞纳金" />
            <Picker x:Name="pickerCalcLateFee" Title="请选择">
                <Picker.Items>
                    <x:String>是</x:String>
                    <x:String>否</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="滞纳金截止日期" />
            <DatePicker x:Name="dpLateFeeEnd" Format="yyyy-MM-dd" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,12,0,24">
                <Button Grid.Column="0" Text="计算" Clicked="OnCalculate"
                        BackgroundColor="#1565C0" TextColor="White" CornerRadius="6" />
                <Button Grid.Column="1" Text="重置" Clicked="OnReset"
                        BackgroundColor="#757575" TextColor="White" CornerRadius="6" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
